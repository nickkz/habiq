# ─── Primary: RentCast (recommended) ─────────────────────────────────────────
# Purpose-built for real estate investors. Free tier: 50 req/month.
# Sign up at: https://app.rentcast.io/app/api-access
RENTCAST_API_KEY=your_rentcast_key_here

# ─── Fallback: Zillow via RapidAPI ────────────────────────────────────────────
# Only needed if not using RentCast.
# Subscribe at: https://rapidapi.com/apimaker/api/zillow56
RAPIDAPI_KEY=your_rapidapi_key_here
ZILLOW_HOST=zillow56.p.rapidapi.com

# ─── Optional: skip-trace owner contact info ──────────────────────────────────
# BatchSkipTracing: https://batchskiptracing.com (~$0.15/record)
BATCH_SKIP_TRACE_KEY=your_batch_skip_trace_key_here

# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-long-random-string
